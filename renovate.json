{
	"$schema": "https://docs.renovatebot.com/renovate-schema.json",
	"extends": ["config:recommended", "schedule:weekly"],
	"lockFileMaintenance": {
		"enabled": true,
		"automerge": true,
		"schedule": ["before 5am on monday"]
	},
	"packageRules": [
		{
			"matchUpdateTypes": ["minor", "patch"],
			"groupName": "{{manager}} non-major dependencies",
			"automerge": true
		}
	]
}
